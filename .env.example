# ============================================================
# LLM Provider — 至少配置一个
# ============================================================

# DeepSeek（推荐，性价比高）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------
# 自定义 provider（兼容 OpenAI / Anthropic 协议的任何 API）
# 协议由 CUSTOM_API_PROTOCOL 指定：openai（默认）或 anthropic
# -----------------------------------------------------------
# CUSTOM_API_KEY=sk-xx
# CUSTOM_BASE_URL=https://your-api-endpoint/v1
# CUSTOM_MODELS=xx
# CUSTOM_API_PROTOCOL=openai
# 注：自定义 provider 的模型名需在 config.ini 中以 custom/ 前缀引用

# ============================================================
# YouTube Data API（可选）
# 仅 uploads 命令（频道视频列表）需要，article/download 不需要
# ============================================================
# YOUTUBE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# 文章投送 — 按需配置
# ============================================================

# Telegram（@BotFather 创建 Bot 获取 Token，频道/群组 ID 用 @userinfobot 查）
TELEGRAM_BOT_TOKEN=1234567890:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# Discord Webhook（频道设置 → 集成 → Webhook 创建）
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxx/xxxxxxxxx

# ============================================================
# 搜索 API Keys（可选，用于 --search 功能）
# ============================================================

# Tavily Search API（https://tavily.com）
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Brave Search API（https://brave.com/search/api/）
# BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
